# EPA Air Quality System (AQS) API credentials
# Register at: https://aqs.epa.gov/data/api/signup?email=your@email.com
EPA_AQS_EMAIL=your_email@example.com
EPA_AQS_KEY=your_aqs_api_key_here

# EPA AirNow API key (for POST /predict/live real-time endpoint)
# Register at: https://docs.airnowapi.org/account/request/
AIRNOW_KEY=your_airnow_api_key_here

# AirNow tuning (all optional — defaults shown)
# AIRNOW_TIMEOUT=60       # HTTP read timeout in seconds. Dense-metro ozone
#                         # requests (~5,500 obs) need more than the old 30s default.
# AIRNOW_BBOX_LAT=0.15    # Bounding-box half-height in decimal degrees (~10 mi).
# AIRNOW_BBOX_LON=0.18    # Bounding-box half-width  in decimal degrees (~10 mi).
#                         # Widen for rural areas with sparse monitors:
#                         #   AIRNOW_BBOX_LAT=0.36  AIRNOW_BBOX_LON=0.45  (±25 mi)

# OpenWeatherMap API key (weather context in /predict/live response)
# Register at: https://openweathermap.org/api
OPENWEATHER_KEY=your_openweather_api_key_here
